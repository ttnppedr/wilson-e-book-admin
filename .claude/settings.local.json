{
  "permissions": {
    "allow": [
      "Bash(vendor/bin/sail bin:*)",
      "mcp__laravel-boost__database-schema",
      "mcp__laravel-boost__read-log-entries",
      "mcp__laravel-boost__search-docs",
      "mcp__laravel-boost__application-info"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "laravel-boost"
  ],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | { read -r f; [[ \"$f\" == *.php ]] && vendor/bin/sail bin pint --parallel --max-processes=4 \"$f\"; } 2>/dev/null || true",
            "timeout": 30,
            "statusMessage": "Running Pint formatter..."
          }
        ]
      }
    ]
  }
}
