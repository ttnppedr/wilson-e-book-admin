APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_TIMEZONE=Asia/Taipei
APP_LOCALE=zh_TW
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
# 本機開發也走 S3（MinIO），與生產相同的 presigned 直傳流程，檔案不落地 app server。
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# 本機開發：MinIO（S3 相容），由 compose.yaml 的 minio 服務提供。
# 首次（或砍掉 sail-minio volume 後）需手動建立 local bucket 並設公開讀（見 MinIO console
# http://localhost:8900，sail/password；bucket 之後存在 volume 內、跨重啟保留）。
# AWS_ENDPOINT 用 OrbStack 網域 + :9000 直連（純 HTTP），讓 presigned 簽章 host 在
# 瀏覽器端與 PHP 容器端一致。生產（Laravel Cloud）改填實際 S3 憑證、移除 AWS_ENDPOINT、
# 並把 AWS_URL 設為 CDN/bucket 公開網址。
AWS_ACCESS_KEY_ID=sail
AWS_SECRET_ACCESS_KEY=password
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=local
AWS_ENDPOINT=http://minio.wilson-e-book-admin.local:9000
AWS_URL=http://minio.wilson-e-book-admin.local:9000/local
AWS_USE_PATH_STYLE_ENDPOINT=true

VITE_APP_NAME="${APP_NAME}"

# Licensing
LICENSING_KEY_SALT=              # 授權碼雜湊鹽值，未設定時預設使用 APP_KEY
LICENSING_KEY_PASSPHRASE=        # Ed25519 簽章金鑰的加密 passphrase
LICENSING_TOKEN_ISSUER=wilson-ebook-admin  # PASETO token 的 issuer claim